ai-deck.online, www.ai-deck.online {
  encode zstd gzip

  handle /api/* {
    reverse_proxy backend:8000 {
      header_up Host {host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-For {remote_host}
    }
  }

  handle /health {
    reverse_proxy backend:8000 {
      header_up Host {host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-For {remote_host}
    }
  }

  handle {
    reverse_proxy frontend:3000
  }
}
